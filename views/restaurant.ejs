<a href="/restaurants" class="muted">← Back to restaurants</a>
<link rel="stylesheet" href="/css/menu-style.css">

<div class="page">
  <header class="restaurant-header">
    <h1><%= restaurant.name %></h1>
    <p class="restaurant-desc"><%= restaurant.description %></p>

    <p class="rating">
      Rating: <strong><%= restaurant.ratingAvg %></strong> / 5
      (<%= restaurant.ratingCount %> reviews)

      <% if (currentUser && restaurant.ownerId && (String(currentUser.id) === String(restaurant.ownerId) || currentUser.role === "admin")) { %>
        <a href="/restaurants/<%= restaurant._id %>/edit" class="btn-primary">Edit Restaurant</a>
      <% } %>
    </p>
  </header>

  <hr>

  <form class="menu-filters" method="get">
    <div class="search-row">
      <div class="search-input-wrapper">
        <button type="button" class="filter-toggle" aria-expanded="false" aria-label="Toggle advanced filters">
          <svg class="filter-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M3 4h18l-7 8v6l-4 2v-8L3 4z" />
          </svg>
        </button>
        <input name="q" type="search" placeholder="Search menu" value="<%= filters.q || '' %>">
      </div>

      <div class="filter-actions">
        <button type="submit" class="btn-primary">Apply Filters</button>
        <button type="button" class="clear-all">Clear All Filters</button>
      </div>
    </div>

    <div class="filter-panel">
      <select name="category">
        <option value="">All categories</option>
        <% categories.forEach(c => { %>
          <option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
      <input name="dietTag" type="text" placeholder="Filter by dietary tag (halal, keto, gluten-free)" value="<%= filters.dietTag || '' %>">

      <input name="minPrice" type="number" step="0.01" placeholder="Min price" value="<%= filters.minPrice || '' %>">
      <input name="maxPrice" type="number" step="0.01" placeholder="Max price" value="<%= filters.maxPrice || '' %>">
      <input name="excludeAllergens" placeholder="Exclude allergens" value="<%= filters.excludeAllergens || '' %>">
    </div>
  </form>

  <h2>Menu</h2>

  <div class="menu-container">
    <% const placeholder = "https://images.unsplash.com/vector-1769004080108-6c81a96475df?q=80&w=1480&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"; %>
  
    <% menuItems.forEach(i => { %>
      <article class="menu-item">
        <h3><%= i.name %></h3>
        <p class="description"><%= i.description %></p>
        <p class="price">$<%= i.price %></p>
<<<<<<< HEAD
