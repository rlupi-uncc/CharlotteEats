          Allergens: <%= (i.allergens || []).join(", ") || "None" %>
        </p>
  
        <% if (i.image && i.image !== placeholder) { %>
          <img src="<%= i.image %>" alt="<%= i.name %>" class="menu-item-img"/>
        <% } %>
  
>>>>>>> origin
      </article>
    <% }) %>
  </div>

  <hr>

  <section class="reservations" id="reservations">
    <h2>Make a Reservation</h2>
  
    <form id="reservation-form" class="reservation-form">
      <div class="form-row">
        <div class="form-group">
          <label for="reservationDate">Date</label>
          <input type="date" id="reservationDate" name="reservationDate" required>
        </div>
  
        <div class="form-group">
          <label for="reservationTime">Time</label>
          <input type="time" id="reservationTime" name="reservationTime" required>
        </div>
      </div>
  
      <div class="form-row">
        <div class="form-group">
          <label for="partySize">Party Size</label>
          <input type="number" id="partySize" name="partySize" min="1" max="20" required>
        </div>
      </div>
  
      <div class="form-group">
        <label for="specialRequests">Special Requests</label>
        <textarea id="specialRequests" name="specialRequests" placeholder="Any allergies, seating requests, or notes?"></textarea>
      </div>
  
      <button type="submit" class="btn-primary reserve-btn">Reserve</button>
    </form>
  
    <p id="reservation-message" class="reservation-message"></p>
  </section>

<script>
  window.RESTAURANT_ID = "<%= restaurant._id %>";
</script>
<script src="/reservation.js"></script>
<script src="/menu.js"></script>

<hr>

  <section class="reviews">
    <h2>Reviews</h2>
    <% reviews.forEach(r => { %>
      <div class="review-item">
        <strong><%= r.authorName %></strong> — <span class="review-rating"><%= r.rating %>/5</span>
        <div class="review-title"><em><%= r.title %></em></div>
        <div class="review-body"><%= r.body %></div>
      </div>
    <% }) %>

    <%# NOTE: This is not yet hooked up to anything %>
    <a href="/reviews?id=<%= restaurant._id %>"><button type="button" class="btn-primary review-btn">Leave a Review</button></a>
  </section>

</div>
