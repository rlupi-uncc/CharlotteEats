<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile Page</title>
  <link rel="stylesheet" href="/css/login-style.css">
  <link rel="stylesheet" href="/css/user-style.css">
</head>

<body>

  <header>
    <h1><a href="/">CharlotteEats</a></h1>

    <div class="header-links-flex">

    <a href="/"><img src="/img/logo/logo_horizontal.png" alt="Charlotte Eats Logo" style="height: 40px; width: 100%;"></a>

      <hr width="2" size="40" />
      <h2><a href="/restaurants">Restaurants List</h2>
      <hr width="2" size="40" />
      <h2><a href="/profile">User Profile</a></h2>

      <hr width="2" size="40" />

      <nav>
        <div class="hamburger-menu">
          <span></span>
          <span></span>
          <span></span>
          <div class="menu-dropdown">
            <a href="/reservations/my">My Reservations</a>
            <a href="/profile">My Profile</a>
            <a href="/reviews/my">My Reviews</a>
          </div>
        </div>
      </nav>

    </div>

  </header>

  <main>
    <div class="profile-container">
      <div class="profile-top">
        <div class="profile-info">

          <div class="profile-picture">
            <img src="<%= user.profilePicture || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.username)}&background=6495ED&color=fff&size=160&font-size=0.6` %>" alt="User avatar" class="avatar">
          </div>

          <!-- Dynamic username -->
          <h2>
            <%= user.username %>
          </h2>

          <!-- Dynamic email -->
          <div class="profile-meta">
            <%= user.email %>
          </div>

          <div class="profile-actions">
            <a href="/edit_profile" class="btn">Edit Profile</a>
            <form action="/auth/logout" method="POST" style="display:inline;">
              <button type="submit" class="btn secondary">Log Out</button>
            </form>
          </div>

          <!-- Placeholder stats (future feature) -->
          <div class="profile-stats">
            <div class="stat">Reservations: <%= reservations.length %>
            </div>
            <div class="stat">Reviews: <%= user.reviewCount %></div>
          </div>

          <section class="profile-reservations">
            <h2>My Reservations</h2>

            <% if (!reservations || reservations.length===0) { %>
              <p class="empty-state">No reservations yet.</p>
              <% } else { %>
                <div class="reservation-cards">
                  <% reservations.forEach(r=> { %>
                    <article class="reservation-card">
                      <div class="reservation-card-top">
                        <h3>
                          <%= r.restaurantId?.name || "Restaurant" %>
                        </h3>
                        <span class="reservation-status <%= r.status %>">
                          <%= r.status %>
                        </span>
                      </div>

                      <div class="reservation-details">
                        <p><strong>Date:</strong>
                          <%= r.reservationDate %>
                        </p>
                        <p><strong>Time:</strong>
                          <%= r.reservationTime %>
                        </p>
                        <p><strong>Party Size:</strong>
                          <%= r.partySize %>
                        </p>
                      </div>

                      <% if (r.specialRequests) { %>
                        <div class="reservation-notes">
                          <strong>Special Requests:</strong>
                          <p>
                            <%= r.specialRequests %>
                          </p>
                        </div>
                        <% } %>
                          <form class="delete-reservation-form" data-reservation-id="<%= r._id %>"
                            data-restaurant-id="<%= r.restaurantId?._id || r.restaurantId %>">
                            <button type="submit" class="btn secondary">Delete Reservation</button>
                          </form>
                    </article>
                    <% }) %>
                </div>
                <% } %>
          </section>

          <section class="profile-reviews">
            <h2>My Most Recent Review</h2>

            <% if (!mostRecentReview) { %>
              <p class="empty-state">No reviews yet.</p>
              <% } else { %>
                <div class="review-cards">
                  <article class="review-card">
                    <div class="review-card-top">
                      <h3>
                        <%= mostRecentReview.restaurantName || "Restaurant" %>
                      </h3>
                      <span class="review-rating">
                        <%= "★".repeat(mostRecentReview.rating) %>
                      </span>
                    </div>

                    <div class="review-details">
                      <p><strong>Title:</strong>
                        <%= mostRecentReview.title || "No title" %>
                      </p>
                      <p><strong>Body:</strong>
                        <%= mostRecentReview.body || "No body" %>
                      </p>
                      <p><strong>Date:</strong>
                        <%= new Date(mostRecentReview.createdAt).toLocaleDateString() %>
                      </p>
                    </div>
                  </article>
                </div>
                <% } %>
          </section>

        </div>
      </div>
    </div>
  </main>
  <script src="/profileReservations.js"></script>
</body>

</html>